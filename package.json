{
  "name": "angular-locale-chain",
  "version": "1.0.0",
  "description": "Configurable locale fallback chains for Angular apps via Transloco. Your pt-BR users deserve pt-PT, not English.",
  "author": "i18nagent.ai",
  "license": "MIT",
  "homepage": "https://github.com/i18n-agent/angular-locale-chain#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/i18n-agent/angular-locale-chain"
  },
  "keywords": [
    "angular",
    "transloco",
    "i18n",
    "locale",
    "fallback",
    "chain",
    "localization",
    "internationalization",
    "ngx-translate"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "@jsverse/transloco": ">=5.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@jsverse/transloco": "^7.0.0",
    "rxjs": "^7.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  }
}
